def _mover_arquivo_seguro(origem, destino_dir):
    os.makedirs(destino_dir, exist_ok=True)
    nome = os.path.basename(origem)
    destino = os.path.join(destino_dir, nome)

    if os.path.exists(destino):
        base, ext = os.path.splitext(nome)
        ts = datetime.now().strftime("%Y%m%d_%H%M%S")
        destino = os.path.join(destino_dir, f"{base}_{ts}{ext}")

    shutil.move(origem, destino)
    print(f"[OK] Arquivo movido para: {destino}")


# =========================================================
# PROCESSAMENTO PRINCIPAL
# =========================================================

def processar_arquivo(caminho_pdf):
    try:
        print(f"\n[INICIO] {caminho_pdf}")

        df_transcricao = extrair_transcricao_segura(caminho_pdf)

        # ✅ BLOQUEIO TRANSCRIÇÃO
        if df_transcricao is None or df_transcricao.empty:
            print("[ERRO] Sem transcrição")
            _mover_arquivo_seguro(caminho_pdf, PASTA_ERROS)
            return

        texto = "\n".join(df_transcricao["TEXTO"].astype(str))[:8000]

        print("\n===== TEXTO ENVIADO PRA LLM =====")
        print(texto[:1000])

        base = os.path.splitext(os.path.basename(caminho_pdf))[0]
        uid = uuid.uuid4().hex[:8]
        id_infografico = f"{base}_{uid}"

        # ✅ CHAMADA LLM
        df_llm = interpretar_transcricao(
            texto=texto,
            id_infografico=id_infografico,
            df_transcricao=df_transcricao,
        )

        # ✅ BLOQUEIO 1 — DF VAZIO
        if df_llm is None or df_llm.empty:
            print("[ERRO] df_llm vazio")
            _mover_arquivo_seguro(caminho_pdf, PASTA_ERROS)
            return

        linha = df_llm.iloc[0]

        # ✅ BLOQUEIO 2 — TUDO VAZIO
        if linha.isnull().all() or (linha.astype(str).str.strip() == "").all():
            print("[ERRO] LLM retornou só campos vazios")
            _mover_arquivo_seguro(caminho_pdf, PASTA_ERROS)
            return

        print("\n===== RESULTADO LLM =====")
        print(linha.to_dict())

        # =========================================================
        # ✅ CAMPOS ESTRUTURAIS
        # =========================================================

        nome_atendente = str(linha.get("LLM_ATENDENTE", "")).strip()
        nome_cliente = str(linha.get("LLM_CLIENTE", "")).strip()

        df_llm.loc[0, "SESSION_ID"] = extrair_session_id(caminho_pdf)
        df_llm.loc[0, "ALIANCA"] = "CLOVER"
        df_llm.loc[0, "CHANNEL"] = "WhatsApp"
        df_llm.loc[0, "HISTORICO"] = "Não aplicável"
        df_llm.loc[0, "TABULACAO_HUMANA"] = "Não informado"

        df_llm.loc[0, "CNPJ"] = extrair_cnpj(df_transcricao) or "Não informado"
        df_llm.loc[0, "TELEFONE"] = extrair_telefone(df_transcricao) or "Não informado"

        df_llm.loc[0, "INICIO_ATENDIMENTO_HUMANO"] = inicio_atendimento_humano(df_transcricao, nome_atendente, nome_cliente)
        df_llm.loc[0, "FIM_ATENDIMENTO_HUMANO"] = fim_atendimento_humano(df_transcricao, nome_atendente, nome_cliente)

        inicio = pd.to_datetime(df_llm.loc[0, "INICIO_ATENDIMENTO_HUMANO"], errors="coerce")
        fim = pd.to_datetime(df_llm.loc[0, "FIM_ATENDIMENTO_HUMANO"], errors="coerce")

        if pd.notna(inicio) and pd.notna(fim):
            total = int((fim - inicio).total_seconds())
            df_llm.loc[0, "TEMPO_TOTAL_ATENDIMENTO_HUMANO"] = f"{total}s"
        else:
            df_llm.loc[0, "TEMPO_TOTAL_ATENDIMENTO_HUMANO"] = "Não aplicável"

        tmin, tmax, tmed = calcular_delays(df_transcricao, nome_atendente, nome_cliente)

        df_llm.loc[0, "TEMPO_MINIMO_DELAY"] = tmin or "Não aplicável"
        df_llm.loc[0, "TEMPO_MAXIMO_DELAY"] = tmax or "Não aplicável"
        df_llm.loc[0, "TEMPO_MEDIO_DELAY"] = tmed or "Não aplicável"

        # =========================================================
        # ✅ GERAR HTML
        # =========================================================

        os.makedirs(PASTA_SAIDA_HTML, exist_ok=True)
        saida_html = os.path.join(PASTA_SAIDA_HTML, f"{id_infografico}.html")

        gerar_infografico(
            TEMPLATE_HTML,
            df_transcricao,
            df_llm,
            saida_html,
        )

        print(f"[OK] Infográfico criado: {saida_html}")

        _mover_arquivo_seguro(caminho_pdf, PASTA_PROCESSADOS)

    except Exception as e:
        print("\n[ERRO] Falha ao processar:", e)
        traceback.print_exc()
        _mover_arquivo_seguro(caminho_pdf, PASTA_ERROS)


def executar_em_lote():
    for f in os.listdir(PASTA_ORIGEM):
        if f.lower().endswith(".pdf"):
            processar_arquivo(os.path.join(PASTA_ORIGEM, f))


if __name__ == "__main__":
    executar_em_lote()
