import os
import shutil
import traceback
import uuid
import re
from datetime import datetime
import pandas as pd

from config import (
    PASTA_ORIGEM,
    PASTA_PROCESSADOS,
    PASTA_ERROS,
    PASTA_SAIDA_HTML,
    TEMPLATE_HTML,
)

from parser_pdf import extrair_transcricao_segura
from interpretador_llm import interpretar_transcricao
from gerador_infografico import gerar_infografico


# =========================================================
# UTILIDADES
# =========================================================

def identificar_tipo_ator(row, nome_atendente="", nome_cliente="") -> str:
    ator_raw = ""
    if "TIPO_ATOR" in row and pd.notna(row["TIPO_ATOR"]):
        ator_raw = str(row["TIPO_ATOR"]).strip()
    elif "ATOR" in row and pd.notna(row["ATOR"]):
        ator_raw = str(row["ATOR"]).strip()

    ator = ator_raw.lower()

    if ator in ("atendente", "humano", "cliente", "bot", "ia"):
        return ator

    if nome_atendente and ator == nome_atendente.strip().lower():
        return "atendente"
    if nome_cliente and ator == nome_cliente.strip().lower():
        return "cliente"

    return ator


def extrair_session_id(caminho_pdf: str) -> str:
    base = os.path.splitext(os.path.basename(caminho_pdf))[0]
    m = re.search(r"(\d{4,})$", base)
    return m.group(1) if m else ""


def extrair_cnpj(df):
    if df is None or df.empty:
        return ""
    texto = " ".join(df["TEXTO"].astype(str))
    m = re.search(r"\b\d{2}\.?\d{3}\.?\d{3}/?\d{4}-?\d{2}\b", texto)
    return m.group(0) if m else ""


def extrair_telefone(df):
    if df is None or df.empty:
        return ""
    texto = " ".join(df["TEXTO"].astype(str))
    m = re.search(r"\b\d{10,11}\b", texto)
    return m.group(0) if m else ""


def inicio_atendimento_humano(df, nome_atendente="", nome_cliente=""):
    if df is None or df.empty:
        return ""
    for _, row in df.iterrows():
        if identificar_tipo_ator(row, nome_atendente, nome_cliente) in ("atendente", "humano"):
            return row.get("DATAHORA")
    return ""


def fim_atendimento_humano(df, nome_atendente="", nome_cliente=""):
    if df is None or df.empty:
        return ""
    humanos = [
        row.get("DATAHORA")
        for _, row in df.iterrows()
        if identificar_tipo_ator(row, nome_atendente, nome_cliente) in ("atendente", "humano")
    ]
    return humanos[-1] if humanos else ""


def calcular_delays(df, nome_atendente="", nome_cliente=""):
    if df is None or df.empty:
        return "", "", ""

    df = df.copy()
    df["DATAHORA"] = pd.to_datetime(df["DATAHORA"], errors="coerce")

    delays = []
    ultima_msg_cliente = None

    for _, row in df.sort_values("DATAHORA").iterrows():
        tipo = identificar_tipo_ator(row, nome_atendente, nome_cliente)

        if tipo == "cliente":
            ultima_msg_cliente = row["DATAHORA"]

        elif tipo in ("atendente", "humano") and ultima_msg_cliente is not None:
            diff = (row["DATAHORA"] - ultima_msg_cliente).total_seconds()
            if diff > 0:
                delays.append(diff)
            ultima_msg_cliente = None

    if not delays:
        return "", "", ""

    tmin = f"{int(min(delays))}s"
    tmax = f"{int(max(delays))}s"
    tmed = f"{int(sum(delays) / len(delays))}s"

    return tmin, tmax, tmed


