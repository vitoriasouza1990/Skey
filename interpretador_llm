# =========================================================
# LIMPEZA DE RESPOSTA
# =========================================================
def _strip_code_fences(s: str) -> str:
    s = s.strip()
    if s.startswith("```"):
        s = re.sub(r"^```[a-zA-Z]*", "", s)
    s = re.sub(r"```$", "", s)
    return s.strip()

# =========================================================
# CHAMADA API
# =========================================================
def chamar_llm(prompt: str) -> dict:
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {API_KEY}"
    }

    payload = {
        "messages": [
            {"role": "system", "content": "Retorne apenas JSON válido."},
            {"role": "user", "content": prompt}
        ],
        "temperature": 0.2
    }

    response = requests.post(API_ENDPOINT, headers=headers, json=payload)

    if response.status_code != 200:
        raise Exception(f"Erro API: {response.text}")

    data = response.json()

    try:
        resposta_texto = data["choices"][0]["message"]["content"]
    except Exception:
        resposta_texto = str(data)

    resposta_texto = _strip_code_fences(resposta_texto)

    try:
        return json.loads(resposta_texto)
    except Exception:
        print("[ERRO] JSON inválido:")
        print(resposta_texto)
        return {campo: "" for campo in SCHEMA_LLM}

# =========================================================
# FUNÇÃO PRINCIPAL
# =========================================================
def interpretar_transcricao(
    texto: str,
    id_infografico: str = None,
    df_transcricao=None
) -> pd.DataFrame:

    prompt = f"""
Você é um analista de qualidade de atendimento via WhatsApp.

Analise a conversa abaixo e retorne APENAS um JSON válido.

Regras:
- Use exatamente as chaves fornecidas
- Use "" se não houver informação
- Não invente dados
- Não coloque comentários

Chaves obrigatórias:
{json.dumps(SCHEMA_LLM, indent=2)}

Transcrição:
\"\"\"
{texto}
\"\"\"
"""

    resposta_llm = chamar_llm(prompt)

    resultado = {}

    for campo in SCHEMA_LLM:
        valor = resposta_llm.get(campo, "")
        resultado[campo] = valor if str(valor).strip() else ""

    resultado["ID_INFOGRAFICO"] = id_infografico

    return pd.DataFrame([resultado])
